rules_version = '2';

// BlowMind Storage rules.
// Upload paths are generated by the app as {area}/{uid}/{uuid} — the
// user-provided filename is never used. Legacy files live at flat
// images/{uid}_{timestamp}_{filename} paths and stay readable only.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function sizeOk() {
      return request.resource.size <= 5 * 1024 * 1024; // 5 MB
    }

    // Post images
    match /images/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && isImage()
        && sizeOk();
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Profile avatars
    match /thumbnails/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && isImage()
        && sizeOk();
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Legacy flat upload paths: readable so existing posts keep their
    // images, but no new writes.
    match /images/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /thumbnails/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
