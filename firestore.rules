rules_version = '2';

// BlowMind Firestore security rules (Stage 4 data model).
//
// Interactions live in subcollections with denormalized counters on the
// post document:
//   posts/{postId}/comments/{commentId}   — one doc per comment
//   posts/{postId}/likes/{uid}            — doc ID = liker's uid
//   posts/{postId}/views/{uid}            — doc ID = viewer's uid
//   bookmarks/{uid_postId}                — one doc per user+post
//
// KNOWN COMPROMISE (documented in docs/DATA_MODEL.md): counter fields on
// the post doc are incremented by clients in the same batch/transaction
// as the interaction write. Rules restrict WHICH fields non-owners can
// touch but cannot verify the increment amount matches a subcollection
// write. Moving counters behind Cloud Functions is the planned hardening
// once server-side code is introduced.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Privileged roles are carried in custom claims set server-side only.
    // A normal user can never grant themselves a role (claims are not
    // client-writable), so this is safe as the authorization source.
    function isModerator() {
      return isSignedIn()
        && (request.auth.token.get('moderator', false) == true
            || request.auth.token.get('admin', false) == true);
    }

    // ------------------------------------------------------------------
    // users/{userId}
    // ------------------------------------------------------------------
    match /users/{userId} {
      // Profiles are visible to signed-in users only.
      // KNOWN LIMITATION: profile docs currently include the email field;
      // splitting private fields out is planned for a later stage.
      allow read: if isSignedIn();

      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'firstName', 'lastName', 'email', 'photoUrl', 'photoURL',
          'headline', 'interests', 'interest', 'category', 'online',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.get('firstName', '') is string
        && request.resource.data.get('firstName', '').size() <= 100
        && request.resource.data.get('lastName', '') is string
        && request.resource.data.get('lastName', '').size() <= 100
        && request.resource.data.get('headline', '') is string
        && request.resource.data.get('headline', '').size() <= 200;

      // Owners may edit their profile but never reassign identity fields.
      allow update: if isOwner(userId)
        && affectedKeys().hasOnly([
          'firstName', 'lastName', 'photoUrl', 'photoURL', 'headline',
          'interests', 'interest', 'category', 'online', 'updatedAt'
        ])
        && request.resource.data.get('firstName', '') is string
        && request.resource.data.get('firstName', '').size() <= 100
        && request.resource.data.get('headline', '') is string
        && request.resource.data.get('headline', '').size() <= 200;

      // Account deletion is a server-controlled operation (soft delete).
      allow delete: if false;
    }

    // ------------------------------------------------------------------
    // posts/{postId}
    // ------------------------------------------------------------------
    match /posts/{postId} {
      // Public content, but content hidden by moderation is visible only
      // to its owner and moderators.
      allow read: if resource == null
        || resource.data.get('moderationStatus', 'ok') != 'removed'
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || isModerator();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 100000
        && request.resource.data.keys().hasOnly([
          'title', 'content', 'imageURL', 'userId', 'author', 'createdAt',
          'tags', 'share', 'commentCount', 'likeCount', 'bookmarkCount',
          'viewCount', 'expands'
        ])
        && request.resource.data.get('commentCount', 0) == 0
        && request.resource.data.get('likeCount', 0) == 0
        && request.resource.data.get('bookmarkCount', 0) == 0
        && request.resource.data.get('viewCount', 0) == 0;

      // Interaction counters (commentCount/likeCount/bookmarkCount/
      // viewCount) are owned by Cloud Functions via the Admin SDK, which
      // bypasses rules — so NO client may write them here.
      //  - Owners may edit their post's content only.
      //  - Anyone may bump `expands` (low-stakes, no subcollection source).
      //  - Moderators may set moderation status.
      allow update: if isSignedIn()
        && (
          (resource.data.userId == request.auth.uid
            && affectedKeys().hasOnly([
              'title', 'content', 'imageURL', 'author', 'tags', 'share'
            ]))
          ||
          affectedKeys().hasOnly(['expands'])
          ||
          (isModerator()
            && affectedKeys().hasOnly(['moderationStatus', 'moderatedAt', 'moderatedBy']))
        );

      allow delete: if isOwner(resource.data.userId) || isModerator();

      // ----------------------------------------------------------------
      // posts/{postId}/comments/{commentId}
      // ----------------------------------------------------------------
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 2000
          && request.resource.data.keys().hasOnly([
            'userId', 'displayName', 'photoURL', 'content', 'createdAt'
          ]);
        // Comments are immutable; authors may delete their own.
        allow update: if false;
        allow delete: if isOwner(resource.data.userId);
      }

      // ----------------------------------------------------------------
      // posts/{postId}/likes/{uid} — doc ID must be the liker's uid
      // ----------------------------------------------------------------
      match /likes/{uid} {
        allow read: if true;
        allow create: if isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly([
            'uid', 'displayName', 'photoURL', 'createdAt'
          ]);
        allow update: if false;
        allow delete: if isOwner(uid);
      }

      // ----------------------------------------------------------------
      // posts/{postId}/views/{uid} — write-once, doc ID = viewer's uid
      // ----------------------------------------------------------------
      match /views/{uid} {
        allow read: if isSignedIn();
        allow create: if isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'createdAt']);
        allow update, delete: if false;
      }
    }

    // ------------------------------------------------------------------
    // bookmarks/{bookmarkId} — ID convention: {uid}_{postId}
    // ------------------------------------------------------------------
    match /bookmarks/{bookmarkId} {
      // Bookmarks are private to their owner.
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.keys().hasOnly([
          'userId', 'postId', 'createdAt'
        ])
        && bookmarkId == request.auth.uid + '_' + request.resource.data.postId;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ------------------------------------------------------------------
    // reports/{reportId} — ID convention: {reporterUid}_{type}_{targetId}
    // ------------------------------------------------------------------
    match /reports/{reportId} {
      // Reporters can see their own reports; moderators see all.
      allow read: if isModerator()
        || (isSignedIn() && resource.data.reporterUid == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.targetType in ['post', 'comment']
        && request.resource.data.reason is string
        && request.resource.data.get('details', '').size() <= 1000
        && request.resource.data.status == 'open'
        && reportId == request.auth.uid + '_' +
             request.resource.data.targetType + '_' +
             request.resource.data.targetId;

      // Reporters may not mutate a filed report; moderators triage it.
      allow update: if isModerator()
        && affectedKeys().hasOnly(['status', 'resolution', 'resolvedAt', 'resolvedBy']);
      allow delete: if false;
    }

    // Everything not matched above is denied (Firestore default), stated
    // here explicitly for reviewers.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
