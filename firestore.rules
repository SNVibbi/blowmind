rules_version = '2';

// BlowMind Firestore security rules.
//
// IMPORTANT: these rules protect the CURRENT (legacy) data model, in which
// comments/likes/bookmarks/views live as arrays inside each post document.
// That model forces one deliberate compromise: any signed-in user may
// update a post's interaction fields (and only those fields). Stage 4
// moves interactions into subcollections, after which post documents
// become owner-write-only. Do not "fix" that here by blocking interaction
// updates — it would break commenting and liking entirely.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ------------------------------------------------------------------
    // users/{userId}
    // ------------------------------------------------------------------
    match /users/{userId} {
      // Profiles are visible to signed-in users only.
      // KNOWN LIMITATION: profile docs currently include the email field;
      // splitting private fields out is planned for the data-model stage.
      allow read: if isSignedIn();

      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'firstName', 'lastName', 'email', 'photoUrl', 'photoURL',
          'headline', 'interests', 'interest', 'category', 'online',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.get('firstName', '') is string
        && request.resource.data.get('firstName', '').size() <= 100
        && request.resource.data.get('lastName', '') is string
        && request.resource.data.get('lastName', '').size() <= 100
        && request.resource.data.get('headline', '') is string
        && request.resource.data.get('headline', '').size() <= 200;

      // Owners may edit their profile but never reassign identity fields.
      allow update: if isOwner(userId)
        && affectedKeys().hasOnly([
          'firstName', 'lastName', 'photoUrl', 'photoURL', 'headline',
          'interests', 'interest', 'category', 'online', 'updatedAt'
        ])
        && request.resource.data.get('firstName', '') is string
        && request.resource.data.get('firstName', '').size() <= 100
        && request.resource.data.get('headline', '') is string
        && request.resource.data.get('headline', '').size() <= 200;

      // Account deletion is a server-controlled operation (soft delete).
      allow delete: if false;
    }

    // ------------------------------------------------------------------
    // posts/{postId}
    // ------------------------------------------------------------------
    match /posts/{postId} {
      // Blog content is public.
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 100000
        && request.resource.data.keys().hasOnly([
          'title', 'content', 'imageURL', 'userId', 'author', 'createdAt',
          'comments', 'likes', 'bookmarks', 'views', 'tags', 'share',
          'expand', 'expands'
        ]);

      // Owners may edit their post but never change its ownership.
      // Everyone else may touch ONLY the interaction fields (legacy
      // embedded-array model — see file header).
      allow update: if isSignedIn()
        && (
          (resource.data.userId == request.auth.uid
            && !affectedKeys().hasAny(['userId', 'createdAt']))
          ||
          affectedKeys().hasOnly([
            'comments', 'likes', 'bookmarks', 'views', 'expand', 'expands'
          ])
        );

      allow delete: if isOwner(resource.data.userId);
    }

    // ------------------------------------------------------------------
    // bookmarks/{bookmarkId}
    // ------------------------------------------------------------------
    match /bookmarks/{bookmarkId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // Everything not matched above is denied (Firestore default), stated
    // here explicitly for reviewers.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
