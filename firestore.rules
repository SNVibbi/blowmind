rules_version = '2';

// BlowMind Firestore security rules (Stage 4 data model).
//
// Interactions live in subcollections with denormalized counters on the
// post document:
//   posts/{postId}/comments/{commentId}   — one doc per comment
//   posts/{postId}/likes/{uid}            — doc ID = liker's uid
//   posts/{postId}/views/{uid}            — doc ID = viewer's uid
//   bookmarks/{uid_postId}                — one doc per user+post
//
// KNOWN COMPROMISE (documented in docs/DATA_MODEL.md): counter fields on
// the post doc are incremented by clients in the same batch/transaction
// as the interaction write. Rules restrict WHICH fields non-owners can
// touch but cannot verify the increment amount matches a subcollection
// write. Moving counters behind Cloud Functions is the planned hardening
// once server-side code is introduced.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ------------------------------------------------------------------
    // users/{userId}
    // ------------------------------------------------------------------
    match /users/{userId} {
      // Profiles are visible to signed-in users only.
      // KNOWN LIMITATION: profile docs currently include the email field;
      // splitting private fields out is planned for a later stage.
      allow read: if isSignedIn();

      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'firstName', 'lastName', 'email', 'photoUrl', 'photoURL',
          'headline', 'interests', 'interest', 'category', 'online',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.get('firstName', '') is string
        && request.resource.data.get('firstName', '').size() <= 100
        && request.resource.data.get('lastName', '') is string
        && request.resource.data.get('lastName', '').size() <= 100
        && request.resource.data.get('headline', '') is string
        && request.resource.data.get('headline', '').size() <= 200;

      // Owners may edit their profile but never reassign identity fields.
      allow update: if isOwner(userId)
        && affectedKeys().hasOnly([
          'firstName', 'lastName', 'photoUrl', 'photoURL', 'headline',
          'interests', 'interest', 'category', 'online', 'updatedAt'
        ])
        && request.resource.data.get('firstName', '') is string
        && request.resource.data.get('firstName', '').size() <= 100
        && request.resource.data.get('headline', '') is string
        && request.resource.data.get('headline', '').size() <= 200;

      // Account deletion is a server-controlled operation (soft delete).
      allow delete: if false;
    }

    // ------------------------------------------------------------------
    // posts/{postId}
    // ------------------------------------------------------------------
    match /posts/{postId} {
      // Blog content is public.
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 100000
        && request.resource.data.keys().hasOnly([
          'title', 'content', 'imageURL', 'userId', 'author', 'createdAt',
          'tags', 'share', 'commentCount', 'likeCount', 'bookmarkCount',
          'viewCount', 'expands'
        ])
        && request.resource.data.get('commentCount', 0) == 0
        && request.resource.data.get('likeCount', 0) == 0
        && request.resource.data.get('bookmarkCount', 0) == 0
        && request.resource.data.get('viewCount', 0) == 0;

      // Owners may edit their post but never change ownership or created
      // date. Everyone else may only bump the interaction counters (the
      // legacy embedded arrays are no longer writable by non-owners).
      allow update: if isSignedIn()
        && (
          (resource.data.userId == request.auth.uid
            && !affectedKeys().hasAny(['userId', 'createdAt']))
          ||
          affectedKeys().hasOnly([
            'commentCount', 'likeCount', 'bookmarkCount', 'viewCount',
            'expands'
          ])
        );

      allow delete: if isOwner(resource.data.userId);

      // ----------------------------------------------------------------
      // posts/{postId}/comments/{commentId}
      // ----------------------------------------------------------------
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 2000
          && request.resource.data.keys().hasOnly([
            'userId', 'displayName', 'photoURL', 'content', 'createdAt'
          ]);
        // Comments are immutable; authors may delete their own.
        allow update: if false;
        allow delete: if isOwner(resource.data.userId);
      }

      // ----------------------------------------------------------------
      // posts/{postId}/likes/{uid} — doc ID must be the liker's uid
      // ----------------------------------------------------------------
      match /likes/{uid} {
        allow read: if true;
        allow create: if isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly([
            'uid', 'displayName', 'photoURL', 'createdAt'
          ]);
        allow update: if false;
        allow delete: if isOwner(uid);
      }

      // ----------------------------------------------------------------
      // posts/{postId}/views/{uid} — write-once, doc ID = viewer's uid
      // ----------------------------------------------------------------
      match /views/{uid} {
        allow read: if isSignedIn();
        allow create: if isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly(['uid', 'createdAt']);
        allow update, delete: if false;
      }
    }

    // ------------------------------------------------------------------
    // bookmarks/{bookmarkId} — ID convention: {uid}_{postId}
    // ------------------------------------------------------------------
    match /bookmarks/{bookmarkId} {
      // Bookmarks are private to their owner.
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.keys().hasOnly([
          'userId', 'postId', 'createdAt'
        ])
        && bookmarkId == request.auth.uid + '_' + request.resource.data.postId;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Everything not matched above is denied (Firestore default), stated
    // here explicitly for reviewers.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
